# =============================================================================
# {{project_name}} — Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the dev server.
#
#   cp .env.example.dev .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO
# -----------------------------------------------------------------------------

DJANGO_SETTINGS_MODULE={{project_name}}.settings.dev

# Defaults to True in dev.py
DEBUG=True

# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=insecure-secret-key-replace-as-soon-as-possible

# Comma-separated. For local dev, localhost and 127.0.0.1 are typical.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated. Required when accessing the dev server from a non-localhost
# origin, e.g. via Cloudflare Tunnel or a local network device.
# Example: http://localhost:8000,https://your-tunnel.trycloudflare.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Email address that receives admin error notifications.
SITE_OWNER=your@gmail.com

# -----------------------------------------------------------------------------
# DATABASE (Neon)
# Use a dev branch or a separate dev database — never point at production data.
# Format: postgresql://user:password@host/dbname?sslmode=require
# Docs: https://neon.tech/docs/connect/connect-from-any-app
# -----------------------------------------------------------------------------

DATABASE_URL=

# -----------------------------------------------------------------------------
# HEALTH CHECK
# A secret token used to protect the health check endpoint from public access.
# Can be any random string.
# -----------------------------------------------------------------------------

HEALTH_CHECK_TOKEN=12345

# -----------------------------------------------------------------------------
# OPTIONAL — only set these if the relevant block in base.py is uncommented
# -----------------------------------------------------------------------------

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Redis + Celery
# REDIS_URL=redis://localhost:6379/0

# Cloudflare R2
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_BUCKET_NAME=
# R2_PUBLIC_CDN_DOMAIN=
# R2_PRIVATE_BUCKET_NAME=
